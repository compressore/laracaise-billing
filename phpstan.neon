includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
    level: 9
    parallel:
        maximumNumberOfProcesses: 1
        minimumNumberOfJobsPerProcess: 1000
    ignoreErrors:
        # Billable is a library trait consumed by host-app models, not used within src/ itself
        -
            identifier: trait.unused
            path: src/Concerns/Billable.php
        # billing() is defined on the Billable trait; middleware resolves it at runtime via
        # method_exists(). PHPStan sees the return type as ?Model and cannot infer trait methods.
        -
            identifier: method.notFound
            path: src/Http/Middleware
