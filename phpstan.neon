includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
    level: 9
    parallel:
        maximumNumberOfProcesses: 1
        minimumNumberOfJobsPerProcess: 1000
    ignoreErrors:
        # Billable is a library trait consumed by host-app models, not used within src/ itself
        -
            identifier: trait.unused
            path: src/Concerns/Billable.php
