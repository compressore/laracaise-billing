{
    "name": "laracaise/billing",
    "description": "A flexible billing package for Laravel applications, with Paystack support and usage-based feature limits.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/laracaise/billing",
    "keywords": [
        "laravel",
        "billing",
        "payments",
        "subscriptions",
        "paystack",
        "usage-tracking",
        "feature-flags",
        "laracaise"
    ],
    "authors": [
        {
            "name": "Christian",
            "email": "christian@twomenandatruck.co.za",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/laracaise/billing/issues",
        "source": "https://github.com/laracaise/billing"
    },
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laracaise\\Billing\\": "src/",
            "Laracaise\\Billing\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laracaise\\Billing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laracaise\\Billing\\LaracaiseBillingServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
